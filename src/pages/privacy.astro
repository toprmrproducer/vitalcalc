---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Privacy Policy — VitalCalc"
	description="VitalCalc's privacy policy: your height and weight never leave your device."
	canonicalPath="/privacy"
>
	<h1 class="text-3xl font-extrabold text-[#221b10] sm:text-4xl">Privacy Policy</h1>
	<div class="mt-7 space-y-5 text-[16px] text-[#4a4234]">
		<p>
			VitalCalc does not upload, store, or transmit any height, weight,
			or result you enter. All BMI calculations happen locally in your
			browser using plain JavaScript. Your data never leaves your
			device.
		</p>
		<p>
			We do not require an account, and we do not save your inputs
			between visits unless your browser itself remembers form values.
		</p>
		<p>
			This site may show advertising via Google AdSense, which can use
			cookies to serve relevant ads. You can control ad personalization
			in your
			<a
				href="https://adssettings.google.com/"
				target="_blank"
				rel="noopener noreferrer"
				class="font-semibold text-[#b8860b] underline"
			>Google Ads Settings</a>.
		</p>
		<p>
			We do not use analytics that identify individual users, and we do
			not sell or share any data because we do not collect any of your
			health information in the first place.
		</p>
	</div>
</Layout>
