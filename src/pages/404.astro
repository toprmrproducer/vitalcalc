---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/+$/, '') + '/';
---

<Layout
	title="Page Not Found — VitalCalc"
	description="This page could not be found."
	canonicalPath="/404"
>
	<div class="py-24 text-center">
		<h1 class="text-4xl font-semibold text-[#2B2013]">404</h1>
		<p class="mt-4 text-[#5C4F3D]">
			That page doesn't exist. <a href={base} class="text-[#B8860B] underline">Back to the homepage</a>.
		</p>
	</div>
</Layout>
