---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/+$/, '') + '/';
---

<Layout
	title="Page Not Found — VitalCalc"
	description="This page could not be found."
	canonicalPath="/404"
>
	<div class="py-24 text-center">
		<h1 class="text-5xl font-extrabold text-[#221b10]">404</h1>
		<p class="mt-5 text-[16px] text-[#4a4234]">
			That page doesn't exist. <a href={base} class="font-semibold text-[#b8860b] underline">Back to the homepage</a>.
		</p>
	</div>
</Layout>
